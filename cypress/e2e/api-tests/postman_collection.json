          "listen": "test",
          "script": {
            "exec": [
              "const response=pm.response.json()\r",
              "console.log(response);\r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is an Object\", function () {\r",
              "    pm.expect(response).to.be.an('Object');\r",
              "});\r",
              "pm.test(\"Item added successfully\", function () {\r",
              "    pm.expect(response.created).to.be.true;\r",
              "});\r",
              "pm.test(\"Item ID is not null\", function () {\r",
              "    pm.expect(response.itemId).to.not.be.null;\r",
              "});\r",
              "pm.test(\"Item ID is a number\", function () {\r",
              "    pm.expect(response.itemId).to.be.a('number');\r",
              "});\r",
              "\r",
              "const itemId=response.itemId;\r",
              "pm.collectionVariables.set('itemId',itemId)"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
