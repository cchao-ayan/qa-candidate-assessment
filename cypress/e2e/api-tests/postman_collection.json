    {
      "name": "Register a Client",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response=pm.response.json();",
              "",
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response contains access token\", function () {",
              "    pm.expect(response).to.have.property('accessToken');",
              "    pm.expect(response.accessToken).to.not.be.empty;",
              "    pm.expect(response.accessToken).to.be.a('string');",
              "});",
              "",
              "const accessToken = response.accessToken;",
              "pm.collectionVariables.set('accessToken',accessToken);",
              "pm.environment.set('accessToken', accessToken);",
              "console.log('token: ' + accessToken);",
              "",
              "const client = JSON.parse(pm.request.body.raw);",
              "//console.log(client);",
              "pm.collectionVariables.set('clientName', client.clientName);",
              "pm.collectionVariables.set('clientEmail', client.clientEmail);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n   \"clientName\": \"{{$randomUserName}}\",\r\n   \"clientEmail\": \"{{$randomEmail}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api-clients",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api-clients"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "pm.test(\"Response is an Object\", function () {\r",
              "    pm.expect(response).to.be.an('Object');\r",
              "});\r",
              "pm.test(\"Cart created successfully\", function () {\r",
              "    pm.expect(response.created).to.be.true;\r",
              "});\r",
              "pm.test(\"Cart ID is not empty\", function () {\r",
              "    pm.expect(response.cartId).to.not.be.empty;\r",
              "});\r",
              "pm.test(\"Cart ID is a string\", function () {\r",
              "    pm.expect(response.cartId).to.be.a('string');\r",
              "});\r",
              "\r",
              "const cartId = response.cartId;\r",
              "pm.collectionVariables.set(\"cartId\", cartId);\r",
              "pm.environment.set(\"cartId\", cartId);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/carts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "carts"
          ]
        }
      },
      "response": []
    },
    {
